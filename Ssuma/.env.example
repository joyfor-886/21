# Ssuma 枢墨 - 环境变量配置
# 复制此文件为 .env 并填入实际值

# API Key 认证（可选，不设置则不启用认证）
SSUMA_API_KEY=

# LLM 提供商 API Keys（至少配置一个）
OPENAI_API_KEY=
CLAUDE_API_KEY=
DEEPSEEK_API_KEY=
GEMINI_API_KEY=
MOONSHOT_API_KEY=
QWEN_API_KEY=
SILICONFLOW_API_KEY=
ZHIPU_API_KEY=

# Redis（可选，用于分布式缓存）
REDIS_URL=redis://localhost:6379/0